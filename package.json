{
  "name": "openspec-ops",
  "version": "0.1.0",
  "description": "Harness-neutral git worktree lifecycle CLI for OpenSpec changes",
  "type": "module",
  "bin": {
    "openspec-ops": "./bin/openspec-ops"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "openspec-ops": "tsx src/cli.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  }
}
