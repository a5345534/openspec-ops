{
  "name": "openspec-ops",
  "version": "0.1.0",
  "description": "OpenSpec ops lifecycle: worktree CLI + Pi skills/extension (explicit start, guided /ops-next, ship/merge/finish; no auto chain)",
  "type": "module",
  "keywords": [
    "pi-package",
    "openspec",
    "worktree",
    "git"
  ],
  "bin": {
    "openspec-ops": "./bin/openspec-ops",
    "openspec-ops-intercept": "./bin/openspec-ops-intercept"
  },
  "files": [
    "bin",
    "dist",
    "src",
    ".pi/extensions",
    ".pi/skills/ops-doctor",
    ".pi/skills/ops-finish",
    ".pi/skills/ops-spec-review",
    ".pi/skills/ops-start",
    ".pi/skills/ops-where",
    ".pi/prompts/ops-doctor.md",
    ".pi/prompts/ops-finish.md",
    ".pi/prompts/ops-spec-review.md",
    ".pi/prompts/ops-start.md",
    ".pi/prompts/ops-where.md",
    "docs/snippets",
    "README.md",
    "package.json",
    "tsconfig.json",
    ".pi/skills/ops-ship",
    ".pi/skills/ops-prune",
    ".pi/prompts/ops-ship.md",
    ".pi/prompts/ops-prune.md",
    ".pi/skills/ops-impl-review",
    ".pi/prompts/ops-impl-review.md",
    ".pi/skills/ops-merge",
    ".pi/prompts/ops-merge.md",
    ".pi/skills/ops-next",
    ".pi/skills/ops-deliver"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "openspec-ops": "tsx src/cli.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prebuild": "rm -rf dist"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "tsx": "^4.20.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    }
  },
  "pi": {
    "extensions": [
      ".pi/extensions/**/*.ts"
    ],
    "skills": [
      ".pi/skills/ops-*/SKILL.md"
    ],
    "prompts": [
      ".pi/prompts/ops-*.md"
    ]
  }
}
